all: SBUS.elf SBUS.bin SBUS.hex size

%.o: %.c
	@echo "  CC  $<"
	@$(CC) $(CFLAGS) $(INCS) -c $< -o $@

SBUS.elf: $(OBJS)
	@echo "  LD  $@"
	@$(CC) $(LDFLAGS) $(OBJS) -o $@
	@echo ""

SBUS.bin: SBUS.elf
	@echo "  BIN $@"
	@$(OBJCOPY) -O binary $< $@

SBUS.hex: SBUS.elf
	@echo "  HEX $@"
	@$(OBJCOPY) -O ihex $< $@

size: SBUS.elf
	@echo ""
	@$(SIZE) $@

clean:
	rm -f $(OBJS) SBUS.elf SBUS.bin SBUS.hex
